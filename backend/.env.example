# ── LLM preset ───────────────────────────────────────────────────────────────
# One line to switch all LLM calls. Options:
#   local          → Ollama (LOCAL_MODEL, default: qwen2.5:14b)
#   openai         → OpenAI (OPENAI_MODEL, default: gpt-4o-mini)
#   gemini         → Gemini 2.5 Flash (GEMINI_MODEL to override)
#   bedrock        → DeepSeek R1 (BEDROCK_MODEL to override)
#   bedrock-haiku  → Claude Haiku 4.5 (BEDROCK_HAIKU_MODEL to override)
#   bedrock-qwen   → Qwen3 32B (BEDROCK_QWEN_MODEL to override)
LLM_PRESET=openai

# ── Model overrides (uncomment + change to override preset default) ───────────
#OPENAI_MODEL=gpt-4o-mini
#GEMINI_MODEL=gemini-2.5-flash
#BEDROCK_MODEL=us.deepseek.r1-v1:0
#BEDROCK_HAIKU_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
#BEDROCK_QWEN_MODEL=qwen/qwen3-32b:0
#LOCAL_MODEL=qwen2.5:14b

# ── OpenAI credentials ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=300

# ── Gemini credentials ────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_TIMEOUT=120

# ── AWS Bedrock credentials ───────────────────────────────────────────────────
BEDROCK_REGION=us-east-1
# Named boto3 profile (e.g. SSO profile). Leave blank to use default chain.
AWS_PROFILE=

# ── Ollama (local) ────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434

# ── Database (Postgres 16) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quotes

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-in-prod

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Seed super admin ──────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@nimai.ai
SEED_ADMIN_PASSWORD=password!123
